# Copy to ".env.local" (with the leading dot). Next.js does not load "env.local".
# Generate a secret:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

MONGODB_URI=mongodb://127.0.0.1:27017/valyou
MONGODB_DB=valyou

# Sign-in sessions (JWT). Required in production (Vercel, `next start`). Min 32 characters.
# In `next dev` only, a built-in dev secret is used if this is missing or too short.
SESSION_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# Optional: higher GitHub API rate limits for credibility analysis
# GITHUB_TOKEN=

# Razorpay — INR wallet top-up → in-app ALGO (see /wallet)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# ALGO credited per ₹1 paid (default 0.01)
# WALLET_ALGO_PER_INR=0.01
# Optional max single top-up in INR
# WALLET_RAZORPAY_MAX_INR=500000
